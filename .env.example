# Security note:
# - Replace every placeholder before running the stack.
# - Use strong secrets (recommended: >=16 chars, mixed case, numbers, symbols).
#
# Core warehouse
POSTGRES_USER=telco_admin
POSTGRES_DB=telco_warehouse
TELCO_POSTGRES_PASSWORD=replace_with_strong_password

# MinIO root account for local stack bootstrap
TELCO_MINIO_ROOT_USER=minio_admin
TELCO_MINIO_ROOT_PASSWORD=replace_with_strong_password

# Airflow metadata database + admin
AIRFLOW_DB_PASSWORD=replace_with_strong_password
AIRFLOW_ADMIN_PASSWORD=replace_with_strong_password
AIRFLOW__CORE__FERNET_KEY=replace_with_32byte_urlsafe_base64_key
# Use the same secret value as AIRFLOW_DB_PASSWORD in this DSN.
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:replace_with_AIRFLOW_DB_PASSWORD@airflow_postgres/airflow

# Airflow runtime connections
# Use TELCO_POSTGRES_PASSWORD and TELCO_MINIO_ROOT_* equivalent values below.
AIRFLOW_CONN_TELCO_WAREHOUSE=postgresql://telco_admin:replace_with_TELCO_POSTGRES_PASSWORD@postgres:5432/telco_warehouse
AIRFLOW_CONN_TELCO_MINIO=aws://replace_with_TELCO_MINIO_ROOT_USER:replace_with_TELCO_MINIO_ROOT_PASSWORD@/?endpoint_url=http%3A%2F%2Fminio%3A9000&region_name=us-east-1

# CLI uploader/verify contract
TELCO_MINIO_ENDPOINT_URL=http://localhost:9000
TELCO_MINIO_REGION=us-east-1
TELCO_MINIO_ACCESS_KEY=replace_with_minio_access_key
TELCO_MINIO_SECRET_KEY=replace_with_minio_secret_key
